{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@director-ai/types": ["./packages/types"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "supabase/functions/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend"
  ]
}
