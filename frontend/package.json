    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@spartan-ng/cli": "^1.0.1",
    "@testing-library/angular": "19.4.1",
    "@types/jest": "30.0.0",
    "angular-eslint": "21.4.0",
    "eslint": "10.3.0",
    "jest": "30.4.2",
