    "test:jest:watch": "jest --config jest.config.ts --watch",
    "test:jest:coverage": "jest --config jest.config.ts --coverage",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\""
