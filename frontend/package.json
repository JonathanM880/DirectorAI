{
  "name": "director-ai-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:jest": "jest --config jest.config.ts",
    "test:jest:watch": "jest --config jest.config.ts --watch",
    "test:jest:coverage": "jest --config jest.config.ts --coverage",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\""
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "21.2.0",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.2.0",
    "@angular/core": "21.2.0",
    "@angular/forms": "21.2.0",
    "@angular/platform-browser": "21.2.0",
    "@angular/router": "21.2.0",
    "@supabase/supabase-js": "2.108.2",
    "rxjs": "7.8.0",
    "tslib": "2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.0",
    "@eslint/js": "10.0.1",
    "@testing-library/angular": "19.4.1",
    "@types/jest": "30.0.0",
    "angular-eslint": "21.4.0",
    "eslint": "10.3.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-angular": "17.0.0",
    "jsdom": "28.0.0",
    "msw": "2.14.6",
    "prettier": "3.8.1",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "4.0.8"
  }
}
